{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "ocp5-olm-update-experience.vercel.app" }],
      "destination": "https://openshift-platform-prototype.vercel.app/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "node-details-gpu-metrics.vercel.app" }],
      "destination": "https://openshift-platform-prototype.vercel.app/:path*",
      "permanent": true
    }
  ],
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }]
}
